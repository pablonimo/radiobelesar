{
  "name": "radiobelesar",
  "version": "0.1.0",
  "description": "Radio Belesar — Mesa de son (soundboard) para a radio escolar do CEIP Belesar",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p server/tsconfig.json",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
