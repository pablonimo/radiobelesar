# Porto interno do contedor (Traefik enruta a este porto)
PORT=3000

# Carpeta de datos persistente (audios + base de datos).
# En Docker móntase aquí un volume; en local pode ser ./data
DATA_DIR=/data

# Clave inicial de acceso. Só se usa a PRIMEIRA vez (cando aínda non hai clave gardada).
# Despois cámbiase desde dentro da aplicación.
ADMIN_PASSWORD=belesar

# Opcional: segredo para asinar a cookie de sesión.
# Se non se indica, xérase automaticamente e gárdase en DATA_DIR/.session_secret
# SESSION_SECRET=

# Opcional: tamaño máximo de subida en bytes (por defecto 100 MB)
# MAX_UPLOAD_BYTES=104857600
